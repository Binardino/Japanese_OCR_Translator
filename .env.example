# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Required ---

# Gemini API key for translation (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Path to a NotoSansCJK font for rendering Japanese text in output images
# Docker: /usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
# macOS:  /Library/Fonts/NotoSansCJK-Regular.ttc
# Ubuntu: /usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

# --- Optional (defaults shown) ---

# Folder where you drop your game screenshots
INPUT_DIR=./input

# Folder where translated results are saved (.txt + .jpg)
OUTPUT_DIR=./output

# Path for the personal vocabulary dictionary JSON
DICT_PATH=./output/word_dictionary.json

# Path to the Jamdict database (populated by: python3 -m jamdict import)
JAMDICT_DB=/root/.jamdict/jamdict.db
